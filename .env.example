# ─── Environment ──────────────────────────────────────────────
NODE_ENV=development
PORT=8000

# ─── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/db?sslmode=require

# ─── Auth (JWT) ───────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# ─── Client ───────────────────────────────────────────────────
CLIENT_URL=http://localhost:3000
